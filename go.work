// go.work ties the repo's modules together for local development, so format
// modules resolve formatkit (and each other) from the sibling directories
// instead of the last published tags. External consumers ignore this file —
// `go get`/`go install` use each module's go.mod requires instead.
go 1.25.0

use (
	./formatkit
	./mermaid
	./openapi
	./tools/schemalint
)
