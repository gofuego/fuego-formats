---
title: "api-server Deployment"
source_path: "k8s/overlays/prod/deployment.yaml"
resource_kind: "Deployment"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-server
  namespace: prod
  labels:
    app: api
    tier: backend
  annotations:
    deploy.example.com/owner: platform
spec:
  replicas: 3
  template:
    metadata:
      labels:
        app: api
        tier: backend
    spec:
      serviceAccountName: api-sa
      containers:
        - name: api
          image: registry.example.com/api:1.4.2
          ports:
            - containerPort: 8080
            - containerPort: 9090
              protocol: UDP
          resources:
            limits:
              cpu: 500m
              memory: 512Mi
            requests:
              cpu: 100m
              memory: 128Mi
          env:
            - name: LOG_LEVEL
              value: info
            - name: DB_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: db-credentials
                  key: password
            - name: FEATURE_FLAGS
              valueFrom:
                configMapKeyRef:
                  name: app-config
                  key: flags
          envFrom:
            - configMapRef:
                name: app-config
          volumeMounts:
            - name: config-vol
              mountPath: /etc/app
            - name: data-vol
              mountPath: /var/data
      initContainers:
        - name: migrate
          image: registry.example.com/migrate:1.4.2
      volumes:
        - name: config-vol
          configMap:
            name: app-config
        - name: tls-vol
          secret:
            secretName: tls-cert
        - name: data-vol
          persistentVolumeClaim:
            claimName: data-pvc
        - name: tmp
          emptyDir: {}
